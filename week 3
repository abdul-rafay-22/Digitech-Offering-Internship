# Step 15: Three Reusable Feature Engineering Functions [cite: 185]
def visualize_distributions(df: pd.DataFrame, cols: list, n_cols: int = 3) -> None: [cite: 185]
    """Creates a multi-panel histogram grid for a list of columns."""
    n_rows = int(np.ceil(len(cols) / n_cols))
    fig, axes = plt.subplots(n_rows, n_cols, figsize=(n_cols * 4, n_rows * 3))
    axes = axes.flatten()
    for i, col in enumerate(cols):
        skew_val = df[col].skew()
        axes[i].hist(df[col].dropna(), bins=30, edgecolor='white')
        axes[i].set_title(f"{col}\nSkew: {skew_val:.2f}") [cite: 185]
    plt.tight_layout()
    plt.show()

def encode_quality_column(series: pd.Series, quality_map: dict = None) -> tuple: [cite: 186]
    """Encodes a quality categorical column using a provided map."""
    if quality_map is None:
        quality_map = {'Ex': 5, 'Gd': 4, 'TA': 3, 'Fa': 2, 'Po': 1, 'NA': 0} [cite: 186]
    encoded = series.fillna('NA').map(quality_map)
    return encoded, quality_map [cite: 187]

def full_scaling_pipeline(X_train: pd.DataFrame, X_test: pd.DataFrame, method: str = 'standard') -> tuple: [cite: 187]
    """Fits scaler on X_train, transforms both."""
    scalers = {'standard': StandardScaler(), 'minmax': MinMaxScaler(), 'robust': RobustScaler()}
    scaler = scalers[method]
    X_train_scaled = pd.DataFrame(scaler.fit_transform(X_train), columns=X_train.columns) [cite: 187]
    X_test_scaled = pd.DataFrame(scaler.transform(X_test), columns=X_test.columns)
    return X_train_scaled, X_test_scaled, scaler [cite: 187]


